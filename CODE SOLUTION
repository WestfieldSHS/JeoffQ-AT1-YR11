TEXT = """
He gasped. So did the people around him. About twenty ghosts had just streamed through the back wall. Pearly-white and slightly transparent, they glided across the room talking to each other and hardly glancing at the first-years. They seemed to be arguing.

- Extract from Harry Potter and the Philosopher's Stone by J.K Rowling
"""
#\n means to start a new line 

print("=== Reading Assistant ===")
print("\nHere is your text:")
print(TEXT)

print("\nDid you find any difficult words?")
print("A: Yes")
print("B: No")

#strip.() is to clean up the user input and upper.() is to turn the text into capital letters. 

choice = input("choose A or B: ").strip().upper()

#difficult_words = [] creates an empty list, while True is an infinite loop, word.lower() converts strings to lowercase 

if choice == "A": 
    print("\nGreat. You can now enter the difficult words.")
    print("Type one word at a time. Type 'done' when finished \n.")
    
    DICTIONARY = {  
    "gasped": "To take a quick, sharp breath - usually because you're shocked, scared or out of breath.",
    "ghosts": "The spirits of people who have died, imagined to appear in the world of the living.",
    "streamed": "To move or flow continuously in one direction, like water flowing in a line.",
    "transparent": "Something you can see through because it is clear.",
    "glided": "To move smoothly and quietly, as if floating, without effort.",
    "glancing": "Taking a quick, brief look at something, usually without turning your head fully or looking for long.",
    "arguing": "Disagreeing with someone and speaking back and forth to explain your different opinions."
}

    difficult_words = []
    while True: 
        word = input("Enter a difficult word: ").strip()
        
        if word in TEXT:
            if word.lower() == "done":
                break 

            elif word not in difficult_words:
                difficult_words.append(word)
            else: 
                print("Word already in difficult words.") 
        elif word.lower() == "done":
            break 
        else: 
            print("Word not in text.")

        print(difficult_words)

    missing = []

    for w in difficult_words:
        if w.lower() not in DICTIONARY: 
            missing.append(w)
    
    if missing: 
        print("\nThe following word(s) have no definition.")
        for m in missing: 
            print(f"-{m}")

            print("\nPlease check again if you've found any difficult words.")
    else: 
        print("\n=== Definitions of Difficult Words ===")
        for w in difficult_words:
            meaning = DICTIONARY.get(w.lower(), "No definition found.")
            print(f"{w}: {meaning}")

elif choice == "B": 
    print("\nAlright. You haven't found any words.")
    difficult_words = []
    print("\nYou may continue reading.")

else: 
    print("\nInvalid choice.")
    difficult_words = []